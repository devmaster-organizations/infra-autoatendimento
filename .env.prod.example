# Copie este arquivo para .env.prod e preencha com seus valores reais.

# Porta do backend no container
API_PORT=3000

# Portas publicadas no host
API_HOST_PORT=3001
FRONTEND_HOST_PORT=3000

# URL do banco (DigitalOcean Managed PostgreSQL)
DATABASE_URL=postgresql://doadmin:SUA_SENHA_AQUI@db-pgsql-nyc3-11663-do-user-34635274-0.e.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# URL pública do frontend (usada por fluxos de email/reset)
# Exemplo: https://app.seudominio.com
FRONTEND_PUBLIC_URL=https://SEU-DOMINIO-DO-FRONTEND

# URL pública que o browser usa para acessar a API
# Exemplo: https://api.seudominio.com/api
# Se estiver sem proxy e usando IP: http://SEU_IP:3001/api
NEXT_PUBLIC_API_BASE_URL=http://SEU_IP_OU_DOMINIO:3001/api

# URL interna usada pelo frontend em runtime dentro da rede Docker
API_INTERNAL_BASE_URL=http://infra-api:3000/api
